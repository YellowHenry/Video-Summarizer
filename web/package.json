{
  "name": "audio-summarizer-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:start": "vite --host 127.0.0.1 --port 5173",
    "preview:verify": "playwright test --grep @verify",
    "preview:session:clear": "node -e \"require('fs').rmSync('.auth', { recursive: true, force: true })\"",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:shots": "playwright test",
    "test:e2e:request": "playwright test --grep @request",
    "test:e2e:request:update": "playwright test --grep @request --update-snapshots"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
